    "dlink": {
      "intents": [
        { "id": "find_other_end",  "label": "Find what's on the other end of this cable",  "cmd": "show lldp remote_ports {iface}" },
        { "id": "find_mac",        "label": "Find MAC address on this port",                "cmd": "show fdb port {iface}" },
        { "id": "port_status",     "label": "Port status (up/down, speed, duplex)",         "cmd": "show ports {iface}" },
        { "id": "port_config",     "label": "Port description / config",                    "cmd": "show ports {iface} description" },
        { "id": "vlan_brief",      "label": "All VLANs on the switch",                       "cmd": "show vlan" },
        { "id": "spanning_tree",   "label": "Spanning Tree state",                           "cmd": "show stp ports {iface}" }
      ],
      "auto_commands": [
        { "name": "Port Status",            "cmd": "show ports {iface}" },
        { "name": "Port Description",       "cmd": "show ports {iface} description" },
        { "name": "LLDP Remote Ports",      "cmd": "show lldp remote_ports {iface}" },
        { "name": "FDB (MAC table)",        "cmd": "show fdb port {iface}" },
        { "name": "ARP Table",              "cmd": "show arpentry" },
        { "name": "VLAN",                   "cmd": "show vlan" },
        { "name": "Spanning Tree",          "cmd": "show stp ports {iface}" }
      ]
    }
  },

  "auto_commands": [
    { "name": "Interface Status",      "cmd": "show interfaces {iface} status" },
    { "name": "Interface Description", "cmd": "show interfaces {iface} description" },
    { "name": "LLDP Neighbor",         "cmd": "show lldp neighbors {iface} detail" },
    { "name": "CDP Neighbor",          "cmd": "show cdp neighbors {iface} detail" },
